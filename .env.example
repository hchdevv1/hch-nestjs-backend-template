###############################################################################
# Application
###############################################################################

APP_NAME=HCH NestJS Backend Template
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000

###############################################################################
# Swagger
###############################################################################

SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

###############################################################################
# Database
###############################################################################

# Supported:
# - postgres
# - mysql

DB_TYPE=postgres

DB_HOST=localhost
DB_PORT=5432

DB_NAME=hch_backend

DB_USERNAME=postgres
DB_PASSWORD=postgres

DB_SSL=false

DB_SYNCHRONIZE=false
DB_LOGGING=false

DB_AUTO_LOAD_ENTITIES=true

DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY=3000

###############################################################################
# Logging
###############################################################################

LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_RETENTION=14d
LOG_ZIPPED_ARCHIVE=true

###############################################################################
# LINE Messaging API
###############################################################################

LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

###############################################################################
# HIS API
###############################################################################

HIS_API_BASE_URL=
HIS_API_USERNAME=
HIS_API_PASSWORD=

###############################################################################
# Upload
###############################################################################

UPLOAD_PATH=uploads

###############################################################################
# Timezone
###############################################################################

TZ=Asia/Bangkok
