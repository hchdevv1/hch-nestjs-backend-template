###############################################################################
# Application
###############################################################################

APP_NAME=HCH Obesity Tracking Backend
APP_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0

###############################################################################
# Swagger
###############################################################################

SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

###############################################################################
# Database
###############################################################################

DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=hch_obesity_tracking

###############################################################################
# TypeORM
###############################################################################

DB_SYNCHRONIZE=false
DB_LOGGING=false

###############################################################################
# Logging
###############################################################################

LOG_LEVEL=info

###############################################################################
# LINE Messaging API
###############################################################################

LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

###############################################################################
# HIS API
###############################################################################

HIS_API_BASE_URL=
HIS_API_USERNAME=
HIS_API_PASSWORD=

###############################################################################
# Upload
###############################################################################

UPLOAD_PATH=uploads

###############################################################################
# Timezone
###############################################################################

TZ=Asia/Bangkok
